entrypoint="main.py"
run="bash -lc 'uvicorn main:app --host 0.0.0.0 --port 8000 --reload & cd frontend && npm run dev -- --host 0.0.0.0 --port 5173'"
modules = ["nodejs-20", "python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "sqlite", "vim-full"]

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 80

[userenv]

[userenv.shared]
CONCEPT_PAGE = "./templates/concept_form.html"
START_PAGE = "./templates/index.html"
